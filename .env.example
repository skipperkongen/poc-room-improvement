# Required
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Required
REPLICATE_API_KEY=
REPLICATE_IMAGE_MODEL=google/nano-banana

# Required — placeholders: {{ONSKE}} {{MALING}} {{OPRYDNING}} {{INDRETNING}} {{BRUGER_CUSTOM}} {{CONSTRAINTS}}
IMAGE_PROMPT_TEMPLATE="You are editing an existing property photo professionally for use in a real estate listing.

The user's overall wishes and target audience (may be empty):
{{ONSKE}}

Changes — wall paint (only if relevant below):
{{MALING}}

Changes — tidying / removal of objects:
{{OPRYDNING}}

Changes — furnishing / addition of furniture and items:
{{INDRETNING}}

Extra instructions from the user:
{{BRUGER_CUSTOM}}

{{CONSTRAINTS}}"

# Required — inserted into the template as {{CONSTRAINTS}}
IMAGE_PROMPT_CONSTRAINTS="Preserve the room's dimensions and structural layout (windows, floors, doors, walls) as in the original photo.
Paint only flat wall surfaces; not crown moulding, skirting, wall panelling, window sills, or similar details. Paint all visible walls.
Preserve camera angle and aspect ratio of the original photo.
Ensure colour-coordinated improvements so furniture and walls harmonise."
